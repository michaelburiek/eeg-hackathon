#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_RUFF="$ROOT_DIR/.venv/bin/ruff"

if [[ ! -x "$VENV_RUFF" ]]; then
  echo "Missing ruff in $ROOT_DIR/.venv" >&2
  echo "Install dev dependencies with: python3 -m pip --python .venv/bin/python install '.[dev]'" >&2
  exit 1
fi

cd "$ROOT_DIR"
exec "$VENV_RUFF" check . "$@"
