# ─── Environment Variables ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Anthropic Claude API — required for scripts/07_inference.py (LLM reports)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace token — required for scripts/06_push_to_hub.py
HF_TOKEN=hf_...

# Weights & Biases — optional experiment tracking (set wandb.enabled: true in config)
WANDB_API_KEY=wandb_...

# Google Sheets experiment tracker — required for scripts/05_sync_to_sheets.py
# Service account JSON: download from Google Cloud Console → IAM → Service Accounts
GSHEETS_SA_JSON=/path/to/service_account.json
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GSHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
